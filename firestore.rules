rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email == 'mayankand1234@gmail.com';
    }

    // --- Songs ---
    match /songs/{songId} {
      function isValidSong(data) {
        return (data.get('title', '') is string) &&
               (data.get('artist', '') is string) &&
               (data.get('audioUrl', '') is string) &&
               (data.get('uploaderId', '') == request.auth.uid);
      }

      allow read: if isSignedIn();
      
      allow create: if isSignedIn() && isValidSong(incoming());
      
      allow update: if isSignedIn() && 
                      (resource.data.uploaderId == request.auth.uid || isSuperAdmin()) && 
                      isValidSong(incoming());
                      
      allow delete: if isSignedIn() && (resource.data.uploaderId == request.auth.uid || isSuperAdmin());
    }

    // --- Playlists ---
    match /playlists/{playlistId} {
      function isValidPlaylist(data) {
        return (data.get('name', '') is string) &&
               (data.get('ownerId', '') == request.auth.uid) &&
               (data.get('songIds', []) is list);
      }

      function isValidPlaylistUpdate() {
        let data = incoming();
        let existing = existing();
        return (isSignedIn() && (existing.ownerId == request.auth.uid || isSuperAdmin())) &&
               (!data.keys().hasAny(['ownerId', 'createdAt'])) && // Prevent changing immutable fields
               (data.get('name', existing.name) is string) &&
               (data.get('songIds', existing.songIds) is list);
      }

      allow read: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isSuperAdmin());
      allow create: if isSignedIn() && isValidPlaylist(incoming()) && incoming().createdAt == request.time;
      allow update: if isValidPlaylistUpdate();
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isSuperAdmin());
    }

    // --- Users ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow list: if isSignedIn() && isSuperAdmin();
      allow write: if isSignedIn() && userId == request.auth.uid;
    }
  }
}
