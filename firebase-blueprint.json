{
  "entities": {
    "Song": {
      "title": "Song",
      "description": "Metadata for an uploaded music track",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "artist": { "type": "string" },
        "audioUrl": { "type": "string" },
        "uploaderId": { "type": "string" },
        "uploaderEmail": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "artist", "audioUrl", "uploaderId", "uploaderEmail", "createdAt"]
    },
    "Playlist": {
      "title": "Playlist",
      "description": "User created collection of songs",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "songIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId", "songIds", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "isAdmin": { "type": "boolean" }
      },
      "required": ["email"]
    }
  },
  "firestore": {
    "/songs/{songId}": {
      "schema": "Song",
      "description": "Global list of songs access controlled by rules"
    },
    "/playlists/{playlistId}": {
      "schema": "Playlist",
      "description": "User playlists"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    }
  }
}
